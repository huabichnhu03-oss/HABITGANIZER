# ============================================================
# HabitPup — Root environment variables
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# Database — PostgreSQL connection string
# Get a free database at https://neon.tech (or use any Postgres host)
# Format: postgresql://user:password@host/dbname?sslmode=require
# ----------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/habitpup?sslmode=require

# ----------------------------------------------------------
# Clerk — Authentication keys
# Sign in at https://clerk.com → select your application → API Keys
# Use TEST/DEVELOPMENT keys for local work, LIVE keys for production.
# CLERK_PUBLISHABLE_KEY and VITE_CLERK_PUBLISHABLE_KEY must be the same value.
# ----------------------------------------------------------
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------
# Session secret — used to sign server-side sessions
# Generate a strong random string, e.g.: openssl rand -base64 32
# ----------------------------------------------------------
SESSION_SECRET=replace-me-with-a-long-random-string

# ----------------------------------------------------------
# Port — the port the API server listens on
# Change if 3001 is already in use on your machine
# ----------------------------------------------------------
PORT=3001

# ----------------------------------------------------------
# Web dev server (Vite / habit-tracker only)
# Must differ from PORT above — if both used PORT=3001, Vite and the API would
# collide and you would see "http proxy error" for every /api request.
# ----------------------------------------------------------
VITE_DEV_PORT=5173

# ----------------------------------------------------------
# Web rewarded ads (NOT AdMob — use GPT on the website)
# If you have AdMob, upgrade the linked AdSense account for your domain:
# https://support.google.com/adsense/answer/6023158
# Then set your rewarded ad unit path from Ad Manager / AdSense (not mobile unit IDs).
# Docs: https://developers.google.com/publisher-tag/samples/display-rewarded-ad
# Test unit: /22639388115/rewarded_web_example
# Local dev only: set to "off" for a timed placeholder (no real ads).
# ----------------------------------------------------------
VITE_GAM_REWARDED_AD_UNIT=/22639388115/rewarded_web_example

# Explicit API origin for Vite’s /api proxy (recommended locally; avoids port mismatch)
API_URL=http://localhost:3001

# ----------------------------------------------------------
# Public support email — shown at https://<your-api-domain>/support (Google Play / App Store)
# ----------------------------------------------------------
SUPPORT_CONTACT_EMAIL=you@yourdomain.com

# ----------------------------------------------------------
# Production CORS — comma-separated origins allowed to call the API
# Required when the web app is on a different host than the API
# (e.g. Vercel frontend + Railway API). Not needed if API rewrites
# proxy /api through the same Vercel domain (see vercel.json).
# ----------------------------------------------------------
# CORS_ORIGINS=https://your-app.vercel.app,https://yourcustomdomain.com

# ----------------------------------------------------------
# Vercel web deploy (Project → Settings → Environment Variables)
# Only these are required on Vercel for the static frontend build:
#   VITE_CLERK_PUBLISHABLE_KEY=pk_live_...
#   BASE_PATH=/
# Optional ad unit (omit to use the Google test unit in code):
#   VITE_GAM_REWARDED_AD_UNIT=/your/gam/path
# Also edit vercel.json / netlify.toml and replace YOUR_API_HOST with your
# Railway (or other) API host, e.g. habitpup.up.railway.app — no https://.
# ----------------------------------------------------------
