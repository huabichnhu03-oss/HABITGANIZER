{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/habit-tracker run build",
  "outputDirectory": "artifacts/habit-tracker/dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_API_HOST/api/:path*"
    },
    {
      "source": "/privacy",
      "destination": "https://YOUR_API_HOST/privacy"
    },
    {
      "source": "/support",
      "destination": "https://YOUR_API_HOST/support"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
