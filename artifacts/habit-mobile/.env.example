# ============================================================
# HabitFlow Mobile — environment variables
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# Clerk — Publishable key for the Expo app
# Sign in at https://clerk.com → select your application → API Keys
# Use TEST/DEVELOPMENT keys for local work, LIVE keys for production.
# Must match the CLERK_PUBLISHABLE_KEY value in the root .env
# ----------------------------------------------------------
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------
# API URL — base URL of the running API server
# For local development this is the API server address on your machine.
# For production point this at your deployed API (e.g. Railway URL).
# ----------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:3001

# ----------------------------------------------------------
# Web origin — base URL of the running web frontend
# Used for OAuth redirects and deep-link handling.
# For local development this is the Vite dev server address.
# ----------------------------------------------------------
EXPO_PUBLIC_WEB_ORIGIN=http://localhost:5173

# ----------------------------------------------------------
# AdMob (Google Mobile Ads) — rewarded ads on Pups screen
# Register the app at https://admob.google.com then create a Rewarded ad unit.
# Android setup: https://developers.google.com/admob/android/quick-start
# Use Google's test IDs locally; set real IDs for store builds.
# ----------------------------------------------------------
# App ID (Android) — format ca-app-pub-xxxxxxxx~yyyyyyyyyy
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-3940256099942544~3347511713
# App ID (iOS)
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-3940256099942544~1458002511
# Rewarded ad unit (step 2) — https://developers.google.com/admob/android/rewarded
# Test unit always returns test ads; replace before Play Store release.
EXPO_PUBLIC_ADMOB_REWARDED_UNIT_ID=ca-app-pub-3940256099942544/5224354917
